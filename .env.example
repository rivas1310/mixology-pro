# =============================================================================
# Base de datos PostgreSQL (local + Railway)
# Copia a `.env` o `.env.local` y rellena los valores.
# =============================================================================

# --- Opción A: una sola URL (simple; válido para local O para Railway en prod) ---
# DATABASE_URL="postgresql://USUARIO:PASSWORD@localhost:5432/mixology_pro"

# --- Opción B: dos URLs y conmutar con DATABASE_TARGET (recomendado en desarrollo) ---
# PostgreSQL en tu máquina
DATABASE_URL_LOCAL="postgresql://postgres:postgres@localhost:5432/mixology_pro"

# Railway: usa la URL PÚBLICA si pruebas desde tu PC (Connect → Public).
# Las URLs con *.railway.internal solo funcionan dentro del deploy en Railway.
DATABASE_URL_RAILWAY="postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway"

# Qué base usa la app Next.js y (por defecto) los scripts db:push:local / db:push:railway
# Valores: local | railway
DATABASE_TARGET="local"

# Opcional: duplica manualmente la URL activa en DATABASE_URL si alguna herramienta
# solo lee esa variable (Prisma CLI con `npm run db:push` sin :local/:railway).

# =============================================================================
# Otras variables del proyecto (ejemplos; ajusta según tu .env real)
# =============================================================================
# NEXTAUTH_SECRET=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
